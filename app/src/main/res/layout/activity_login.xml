<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKGROUND -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_cave"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- BACK BUTTON -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:padding="8dp"
        android:scaleType="centerInside"
        android:src="@android:drawable/ic_media_previous"
        android:background="@drawable/bg_button_settings"
        android:contentDescription="@string/back"
        app:tint="@color/gold_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- LOGIN PANEL -->
    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_panel"
        android:padding="28dp"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LOGO -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:adjustViewBounds="true"
            android:src="@drawable/logo_kitago_main"
            android:contentDescription="@null" />

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subtitle"
            android:textColor="@color/subtitle"
            android:textSize="12sp"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="32dp"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />

        <!-- EMAIL ADDRESS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/email_address"
            android:textAllCaps="true"
            android:textColor="@color/text_dark"
            android:textSize="10sp"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="8dp"
            android:labelFor="@+id/etEmail"
            tools:ignore="SmallSp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:textSize="12sp"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"
            android:hint="email@example.com"
            android:inputType="textEmailAddress" />

        <!-- PASSWORD -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password"
            android:textAllCaps="true"
            android:textColor="@color/text_dark"
            android:textSize="10sp"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="8dp"
            android:labelFor="@+id/etPassword"
            tools:ignore="SmallSp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:textSize="12sp"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="8dp"
            android:inputType="textPassword"
            android:importantForAutofill="no" />

        <!-- FORGOT PASSWORD -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FORGOT PASSWORD?"
            android:textSize="8sp"
            android:textColor="@color/link_teal"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginBottom="20dp"
            android:layout_gravity="end"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="4dp"
            tools:ignore="SmallSp" />

        <!-- SIGN IN BUTTON -->
        <TextView
            android:id="@+id/btnSignIn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/sign_in"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="#000000"
            android:fontFamily="@font/press_start_2p"
            android:background="@drawable/bg_button_teal"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true"
            tools:ignore="SmallSp" />

        <!-- SOCIAL DIVIDER -->
        <View
            android:layout_width="200dp"
            android:layout_height="2dp"
            android:background="#44000000"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or_sign_in_using"
            android:textSize="8sp"
            android:textColor="@color/text_muted"
            android:fontFamily="@font/press_start_2p"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            tools:ignore="SmallSp" />

        <!-- GOOGLE SIGN IN BUTTON -->
        <LinearLayout
            android:id="@+id/ivGoogle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_google_button"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_google_logo"
                android:scaleType="centerInside"
                android:contentDescription="@string/google"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOOGLE"
                android:textSize="10sp"
                android:textColor="@color/text_dark"
                android:fontFamily="@font/press_start_2p"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <!-- REGISTER LINK -->
        <TextView
            android:id="@+id/tvRegisterNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_here"
            android:textSize="9sp"
            android:gravity="center"
            android:textColor="@color/text_dark"
            android:fontFamily="@font/press_start_2p"
            android:clickable="true"
            android:focusable="true"
            android:lineSpacingExtra="6dp"
            android:layout_gravity="center_horizontal"
            tools:ignore="SmallSp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
