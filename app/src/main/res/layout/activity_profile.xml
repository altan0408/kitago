<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- BACKGROUND -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_cave"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- TOP BAR -->
    <RelativeLayout
        android:id="@+id/profileTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackProfile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/press_start_2p"
            android:text="@string/profile_title"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="1" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/profileTopBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- AVATAR SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/ivLargeAvatar"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:src="@drawable/logo_kitago_main"
                        android:padding="6dp"
                        android:background="@drawable/bg_button_gold"
                        android:contentDescription="@string/user_large_avatar" />
                    <ImageView
                        android:id="@+id/ivCameraIcon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/white"
                        android:background="@drawable/bg_stone_tablet"
                        android:padding="5dp"
                        android:contentDescription="@string/user_large_avatar" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:id="@+id/tvUsernameProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/press_start_2p"
                        android:text="@string/loading"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:shadowColor="#000000"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="1" />
                    <ImageButton
                        android:id="@+id/btnEditUsername"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="8dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/edit_username"
                        app:tint="@color/gold_light" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvEmailProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/days_remaining_placeholder"
                    android:textColor="@color/white"
                    android:alpha="0.7"
                    android:textSize="7sp"
                    tools:ignore="SmallSp" />

                <TextView
                    android:id="@+id/tvLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/level_placeholder"
                    android:textColor="@color/gold_dark"
                    android:textSize="12sp" />

                <ProgressBar
                    android:id="@+id/profileXpBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="200dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="8dp"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_xp_bar" />

                <TextView
                    android:id="@+id/tvXpLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/xp_label_placeholder"
                    android:textColor="@color/gold_light"
                    android:textSize="7sp"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <!-- PENDING REQUESTS -->
            <LinearLayout
                android:id="@+id/requestsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stone_tablet"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="24dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/pending_requests"
                    android:textColor="#333333"
                    android:textSize="10sp"
                    tools:ignore="SmallSp" />
                <LinearLayout
                    android:id="@+id/requestsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- BADGE ROOM -->
            <LinearLayout
                android:id="@+id/badgeRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/badge_room"
                    android:textColor="@color/text_dark"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp"
                    tools:ignore="SmallSp" />

                <GridLayout
                    android:id="@+id/badgeGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:gravity="center">
                </GridLayout>
            </LinearLayout>

            <!-- PARTY MEMBERS -->
            <LinearLayout
                android:id="@+id/friendsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stone_tablet"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/press_start_2p"
                        android:text="@string/party_members"
                        android:textColor="#333333"
                        android:textSize="10sp"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/btnAddFriend"
                        tools:ignore="SmallSp" />
                    <ImageButton
                        android:id="@+id/btnAddFriend"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:src="@android:drawable/ic_input_add"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/invite_friends" />
                </RelativeLayout>
                <LinearLayout
                    android:id="@+id/friendsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- STATS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/stats_title"
                    android:textColor="@color/text_dark"
                    android:textSize="10sp"
                    android:layout_marginBottom="16dp"
                    tools:ignore="SmallSp" />
                <TextView
                    android:id="@+id/tvWins"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/wins_placeholder"
                    android:textColor="@color/gold_dark"
                    android:textSize="10sp"
                    android:layout_marginBottom="10dp"
                    tools:ignore="SmallSp" />
                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/streak_placeholder"
                    android:textColor="@color/orange_button"
                    android:textSize="10sp"
                    android:layout_marginBottom="10dp"
                    tools:ignore="SmallSp" />
                <TextView
                    android:id="@+id/tvTotalSaved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/total_saved_placeholder"
                    android:textColor="@color/hp_green"
                    android:textSize="10sp"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <!-- ACCOUNT SECTION -->
            <LinearLayout
                android:id="@+id/accountSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:text="@string/account"
                    android:textColor="@color/text_dark"
                    android:textSize="10sp"
                    android:layout_marginBottom="16dp"
                    tools:ignore="SmallSp" />

                <TextView
                    android:id="@+id/btnChangeEmail"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_teal"
                    android:fontFamily="@font/press_start_2p"
                    android:gravity="center"
                    android:text="CHANGE EMAIL"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="SmallSp" />

                <TextView
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_teal"
                    android:fontFamily="@font/press_start_2p"
                    android:gravity="center"
                    android:text="CHANGE PASSWORD"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:clickable="true"
                    android:focusable="true"
                    tools:ignore="SmallSp" />
            </LinearLayout>

            <!-- VIEWER ACTIONS -->
            <TextView
                android:id="@+id/btnUnfriend"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_orange"
                android:fontFamily="@font/press_start_2p"
                android:gravity="center"
                android:text="@string/unfriend"
                android:textColor="#000000"
                android:textSize="12sp"
                android:visibility="gone"
                tools:ignore="SmallSp" />

            <!-- OWNER ACTIONS -->
            <TextView
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_orange"
                android:fontFamily="@font/press_start_2p"
                android:gravity="center"
                android:text="@string/sign_out"
                android:textColor="#000000"
                android:textSize="12sp"
                tools:ignore="SmallSp" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_button_gold"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageButton android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@android:drawable/ic_menu_view" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/home" />
        <ImageButton android:id="@+id/navGoals" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@android:drawable/ic_menu_compass" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/goals" />
        <ImageButton android:id="@+id/navAdd" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@android:drawable/ic_input_add" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/add" />
        <ImageButton android:id="@+id/navChallenges" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@android:drawable/btn_star_big_on" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/challenges" />
        <ImageButton android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:src="@android:drawable/ic_menu_myplaces" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/profile" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
